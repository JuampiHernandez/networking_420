# ============================================================================
# Task402 environment
#
# The app runs in a safe "sim" mode when keys are absent (the x402 wire
# protocol still runs end-to-end; settlement is mocked). Fill these in to go
# fully on-chain on Base Sepolia with real Privy onboarding + a real LLM.
# ============================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ---- Privy (client onboarding + embedded wallet) ----
# https://dashboard.privy.io  -> App settings
NEXT_PUBLIC_PRIVY_APP_ID=
# The escrow/treasury address the creator funds (should match TREASURY_PRIVATE_KEY's address)
NEXT_PUBLIC_ESCROW_ADDRESS=

# ---- x402 (agent buyer + tool seller) ----
# Funded Base Sepolia wallet the AGENT uses to pay x402 tools (needs testnet USDC).
AGENT_PRIVATE_KEY=
# Address that RECEIVES x402 tool payments (the "tool/API seller").
TOOL_SELLER_ADDRESS=
# Facilitator that verifies + settles payments. x402.org works for Base Sepolia.
X402_FACILITATOR_URL=https://x402.org/facilitator

# ---- Escrow / payouts ----
# Wallet controlling the escrow that pays agents / refunds creators.
TREASURY_PRIVATE_KEY=

# ---- LLM (agent reasoning + drafting + chat) ----
LLM_PROVIDER=openai            # openai | anthropic
LLM_MODEL=gpt-4o-mini          # e.g. gpt-4o-mini, claude-3-5-sonnet-latest
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Resend (real outreach email; falls back to sim when empty) ----
# https://resend.com -> API Keys
RESEND_API_KEY=
# Verified sender. Defaults to Resend's shared onboarding sender for quick demos.
RESEND_FROM=Networking Agent <onboarding@resend.dev>

# ---- ElevenLabs (AI voice: agent calls prospects + in-browser voice chat) ----
# https://elevenlabs.io -> Conversational AI
ELEVENLABS_API_KEY=
# Agent + phone number used for OUTBOUND calls the agent places to contacts.
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# Agent id for the in-browser voice widget you talk to (public).
NEXT_PUBLIC_ELEVENLABS_VOICE_AGENT_ID=

# ---- Demo overrides: route ALL outreach to you so you can see it land ----
# When set, every email/call the agent sends goes here instead of the contact.
# For CALLS: Twilio trial accounts can ONLY dial verified numbers — add this
# number at console.twilio.com → Phone Numbers → Verified Caller IDs.
DEMO_CONTACT_EMAIL=
DEMO_CONTACT_PHONE=
